#include <bits/stdc++.h>
using namespace std;
using ll= long long;
int main() {
    int t; cin>>t;
    while(t--){
        ll n; cin>>n;
        vector<ll>a(n);
        for (auto &i : a){
            cin>>i;
        }
        bool possible = false;
        sort(a.begin(), a.end());
        for(int i=0; i<n-1 ; i++){
            if( a[i]== a[i+1]){
                possible = true;
                break;
            }
        }
        if(possible){
            cout<<"YES
";
        }
        else cout<<"NO
";
    }
 
    return 0;
}